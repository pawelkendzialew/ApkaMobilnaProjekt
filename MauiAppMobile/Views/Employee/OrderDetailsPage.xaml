<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiAppMobile.ViewModels.Employee"
             x:Class="MauiAppMobile.Views.Employee.OrderDetailsPage"
             x:DataType="vm:OrderDetailsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- Status Badge -->
            <Frame BackgroundColor="{Binding Order.StatusColor}" 
                   Padding="15" 
                   CornerRadius="12"
                   HasShadow="False">
                <Label Text="{Binding Order.StatusText}" 
                       TextColor="White" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <!-- Tytuł -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="12" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Tytuł zlecenia" 
                           TextColor="{StaticResource Gray600}" 
                           FontSize="14"/>
                    <Label Text="{Binding Order.Title}" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Data i Godzina -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="12" HasShadow="False">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15">
                    <Label Grid.Row="0" Grid.Column="0" 
                           Text="📅 Data" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray600}"/>
                    <Label Grid.Row="1" Grid.Column="0" 
                           Text="{Binding Order.OrderDate, StringFormat='{0:dd MMMM yyyy}'}" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>

                    <Label Grid.Row="0" Grid.Column="1" 
                           Text="🕐 Godzina" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray600}"/>
                    <Label Grid.Row="1" Grid.Column="1" 
                           Text="{Binding Order.StartTime, StringFormat='{0:hh\\:mm}'}" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                </Grid>
            </Frame>

            <!-- Trasa -->
            <Frame BackgroundColor="White" 
                   BorderColor="{StaticResource Primary}"
                   Padding="15" 
                   CornerRadius="12"
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🗺️ Trasa" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🏁" FontSize="18"/>
                        <Label Text="{Binding Order.RouteFrom}" 
                               FontSize="15"
                               TextColor="{StaticResource Gray900}"/>
                    </HorizontalStackLayout>

                    <Label Text="⬇️" 
                           FontSize="16" 
                           Margin="8,0,0,0"
                           TextColor="{StaticResource Primary}"/>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🏁" FontSize="18"/>
                        <Label Text="{Binding Order.RouteTo}" 
                               FontSize="15"
                               TextColor="{StaticResource Gray900}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Pojazd -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="12" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🚐 Pojazd" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                    <Label Text="{Binding Order.Vehicle.Brand}" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>
                    <Label Text="{Binding Order.Vehicle.Model}" 
                           FontSize="16"
                           TextColor="{StaticResource Gray600}"/>
                    <Label Text="{Binding Order.Vehicle.RegistrationNumber}" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Dodatkowe info (jeśli istnieje) -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="False"
                   IsVisible="{Binding Order.AdditionalInfo, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ℹ️ Dodatkowe informacje" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray600}"/>
                    <Label Text="{Binding Order.AdditionalInfo}" 
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Załoga (jeśli istnieje) -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="False"
                   IsVisible="{Binding Order.CrewInfo, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="👥 Załoga" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray600}"/>
                    <Label Text="{Binding Order.CrewInfo}" 
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Firma (jeśli istnieje) -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="False"
                   IsVisible="{Binding Order.CompanyInfo, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🏢 Firma" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray600}"/>
                    <Label Text="{Binding Order.CompanyInfo}" 
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- ⏱️ LICZNIK CZASU (widoczny podczas realizacji) -->
            <Frame BackgroundColor="{StaticResource Success}" 
                   Padding="20" 
                   CornerRadius="12"
                   HasShadow="False"
                   IsVisible="{Binding IsTimerRunning}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⏱️ Czas pracy" 
                           TextColor="White" 
                           FontSize="16" 
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding ElapsedTimeText}" 
                           TextColor="White" 
                           FontSize="42" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           FontFamily="Courier New"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Czas pracy (po zakończeniu) -->
            <Frame BackgroundColor="White"
                   BorderColor="{StaticResource Success}"
                   Padding="15" 
                   CornerRadius="12"
                   HasShadow="False"
                   IsVisible="{Binding Order.WorkDurationMinutes, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="✅ Zlecenie zakończone" 
                           TextColor="{StaticResource Success}" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding Order.WorkDurationText}" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Success}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Powód odrzucenia (jeśli odrzucone) -->
            <Frame BackgroundColor="#FFEBEE"
                   BorderColor="{StaticResource Danger}"
                   Padding="15" 
                   CornerRadius="12"
                   HasShadow="False"
                   IsVisible="{Binding Order.RejectionReason, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="❌ Powód odrzucenia" 
                           TextColor="{StaticResource Danger}" 
                           FontSize="14" 
                           FontAttributes="Bold"/>
                    <Label Text="{Binding Order.RejectionReason}" 
                           FontSize="14"
                           TextColor="{StaticResource Danger}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Przyciski Akcji -->
            <VerticalStackLayout Spacing="10" Margin="0,10,0,20">

                <!-- Przyjmij -->
                <Button Text="✓ Przyjmij zlecenie" 
                        Command="{Binding AcceptOrderCommand}"
                        IsVisible="{Binding CanAccept}"
                        BackgroundColor="{StaticResource Success}" 
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="10"/>

                <!-- Odrzuć -->
                <Button Text="✗ Odrzuć zlecenie" 
                        Command="{Binding RejectOrderCommand}"
                        IsVisible="{Binding CanReject}"
                        BackgroundColor="{StaticResource Danger}" 
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="10"/>

                <!-- Rozpocznij -->
                <Button Text="▶ Rozpocznij zlecenie" 
                        Command="{Binding StartOrderCommand}"
                        IsVisible="{Binding CanStart}"
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="10"/>

                <!-- Zakończ -->
                <Button Text="■ Zakończ zlecenie" 
                        Command="{Binding CompleteOrderCommand}"
                        IsVisible="{Binding CanComplete}"
                        BackgroundColor="{StaticResource Warning}" 
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="10"/>

                <!-- Powrót -->
                <Button Text="← Powrót" 
                        Command="{Binding BackCommand}"
                        BackgroundColor="{StaticResource Gray600}" 
                        TextColor="White"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="10"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                             IsVisible="{Binding IsBusy}"
                             Color="{StaticResource Primary}"
                             HeightRequest="50"
                             WidthRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>