<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiAppMobile.ViewModels.Employee"
             xmlns:models="clr-namespace:MauiAppMobile.Models"
             x:Class="MauiAppMobile.Views.Employee.EmployeeDashboardPage">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- Nagłówek -->
        <Frame Grid.Row="0" 
               BackgroundColor="{StaticResource Primary}" 
               Padding="20" 
               CornerRadius="0"
               HasShadow="True"
               Margin="0">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="{Binding CurrentUser.FullName}" 
                           TextColor="White" 
                           FontSize="22" 
                           FontAttributes="Bold"/>
                    <Label Text="👤 Pracownik" 
                           TextColor="White" 
                           FontSize="14"
                           Opacity="0.9"/>
                </VerticalStackLayout>

                <Button Grid.Column="1" 
                        Text="🚪 Wyloguj" 
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="{StaticResource Danger}" 
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="8"
                        Padding="15,10"/>
            </Grid>
        </Frame>

        <!-- Lista zleceń -->
        <RefreshView Grid.Row="1" 
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}"
                     Margin="10">
            <CollectionView ItemsSource="{Binding Orders}"
                           SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="30" VerticalOptions="Center">
                        <Label Text="📋" 
                               FontSize="60"
                               HorizontalTextAlignment="Center"
                               Opacity="0.3"/>
                        <Label Text="Brak zleceń" 
                               HorizontalTextAlignment="Center"
                               FontSize="20" 
                               TextColor="{StaticResource Gray600}"
                               FontAttributes="Bold"
                               Margin="0,10,0,5"/>
                        <Label Text="Nowe zlecenia pojawią się tutaj" 
                               HorizontalTextAlignment="Center"
                               FontSize="14" 
                               TextColor="{StaticResource Gray600}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Order">
                        <Frame Margin="0,0,0,10" 
                               Padding="15" 
                               HasShadow="True"
                               BackgroundColor="White"
                               BorderColor="{Binding StatusColor}"
                               CornerRadius="12">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OrderTappedCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                                <!-- Tytuł i status -->
                                <Label Grid.Row="0" Grid.Column="0" 
                                       Text="{Binding Title}"
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}"/>

                                <Frame Grid.Row="0" Grid.Column="1" 
                                       BackgroundColor="{Binding StatusColor}"
                                       Padding="10,5" 
                                       CornerRadius="15"
                                       HasShadow="False">
                                    <Label Text="{Binding StatusText}" 
                                           TextColor="White" 
                                           FontSize="12"
                                           FontAttributes="Bold"/>
                                </Frame>

                                <!-- Data i godzina -->
                                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" 
                                                      Spacing="15" 
                                                      Margin="0,8,0,0">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="📅" FontSize="16"/>
                                        <Label Text="{Binding OrderDate, StringFormat='{0:dd.MM.yyyy}'}"
                                               FontSize="14" 
                                               TextColor="{StaticResource Gray600}"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="🕐" FontSize="16"/>
                                        <Label Text="{Binding StartTime, StringFormat='{0:hh\\:mm}'}"
                                               FontSize="14" 
                                               TextColor="{StaticResource Gray600}"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Separator -->
                                <BoxView Grid.Row="2" Grid.ColumnSpan="2"
                                        HeightRequest="1"
                                        BackgroundColor="{StaticResource Gray200}"
                                        Margin="0,10"/>

                                <!-- Trasa -->
                                <VerticalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="5">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🏁" FontSize="16"/>
                                        <Label Text="{Binding RouteFrom}" 
                                               FontSize="15"
                                               TextColor="{StaticResource Gray900}"/>
                                    </HorizontalStackLayout>

                                    <Label Text="⬇️" 
                                           FontSize="14" 
                                           Margin="8,0,0,0"
                                           TextColor="{StaticResource Primary}"/>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🏁" FontSize="16"/>
                                        <Label Text="{Binding RouteTo}" 
                                               FontSize="15"
                                               TextColor="{StaticResource Gray900}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Pojazd -->
                                <Frame Grid.Row="4" Grid.ColumnSpan="2"
                                       BackgroundColor="{StaticResource Gray100}"
                                       Padding="10"
                                       CornerRadius="8"
                                       HasShadow="False"
                                       Margin="0,10,0,0">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🚐" FontSize="18"/>
                                        <Label Text="{Binding Vehicle.DisplayName}" 
                                               FontSize="14" 
                                               TextColor="{StaticResource Primary}"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Frame>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>