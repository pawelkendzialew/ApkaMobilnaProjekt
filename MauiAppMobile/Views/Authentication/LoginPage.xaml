<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiAppMobile.ViewModels.Authentication"
             x:Class="MauiAppMobile.Views.Authentication.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Logo/Tytuł -->
            <Frame BackgroundColor="{StaticResource Primary}" 
                   Padding="20" 
                   CornerRadius="15"
                   HasShadow="False"
                   Margin="0,0,0,30">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🚐" 
                           FontSize="60"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="System Zarządzania"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Zleceniami Transportowymi"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Formularz logowania -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   CornerRadius="15"
                   HasShadow="False">
                <VerticalStackLayout Spacing="15">

                    <!-- Wybór Roli -->
                    <Label Text="Wybierz rolę:" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="👤 Pracownik"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontSize="14"
                                Clicked="OnEmployeeRoleSelected"/>

                        <Button Grid.Column="1"
                                Text="👔 Administrator"
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="White"
                                FontSize="14"
                                Clicked="OnAdminRoleSelected"/>
                    </Grid>

                    <Label Text="{Binding SelectedRole}"
                           FontSize="12"
                           TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center"
                           Margin="0,-10,0,0"/>

                    <!-- Separator -->
                    <BoxView HeightRequest="1" 
                             BackgroundColor="{StaticResource Gray300}"
                             Margin="0,10,0,10"/>

                    <!-- Nazwa użytkownika -->
                    <Label Text="Nazwa użytkownika:" 
                           FontSize="16"
                           TextColor="{StaticResource Gray900}"/>
                    <Frame BorderColor="{StaticResource Gray300}" 
                           Padding="0" 
                           CornerRadius="8"
                           HasShadow="False">
                        <Entry Text="{Binding Username}"
                               Placeholder="Wpisz nazwę użytkownika"
                               ClearButtonVisibility="WhileEditing"
                               Margin="10,0"/>
                    </Frame>

                    <!-- Hasło -->
                    <Label Text="Hasło:" 
                           FontSize="16"
                           TextColor="{StaticResource Gray900}"/>
                    <Frame BorderColor="{StaticResource Gray300}" 
                           Padding="0" 
                           CornerRadius="8"
                           HasShadow="False">
                        <Entry Text="{Binding Password}"
                               Placeholder="Wpisz hasło"
                               IsPassword="True"
                               ClearButtonVisibility="WhileEditing"
                               Margin="10,0"/>
                    </Frame>

                    <!-- Przycisk logowania -->
                    <Button Text="🔓 Zaloguj się"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="55"
                            CornerRadius="10"
                            Margin="0,15,0,0"/>

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                     IsVisible="{Binding IsBusy}"
                                     Color="{StaticResource Primary}"
                                     HeightRequest="40"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Dane testowe -->
            <Frame BackgroundColor="#FFFDE7" 
                   Padding="15" 
                   CornerRadius="10"
                   BorderColor="{StaticResource Warning}"
                   Margin="0,10,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ℹ️ Dane testowe:" 
                           FontAttributes="Bold"
                           FontSize="14"/>
                    <Label Text="👔 Admin: admin / password123" 
                           FontSize="13"/>
                    <Label Text="👤 Pracownik: pnowak / password123" 
                           FontSize="13"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>