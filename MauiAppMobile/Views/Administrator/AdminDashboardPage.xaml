<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMobile.Views.Administrator.AdminDashboardPage"
             Title="Panel Administratora"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <Label Text="👔" 
               FontSize="80"
               HorizontalTextAlignment="Center"/>

        <Label Text="Panel Administratora"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"/>

        <Label Text="🚧 W BUDOWIE 🚧"
               FontSize="20"
               TextColor="{StaticResource Warning}"
               HorizontalTextAlignment="Center"
               Margin="0,20,0,0"/>

        <Label Text="Funkcje administratora będą dostępne wkrótce:"
               FontSize="16"
               HorizontalTextAlignment="Center"
               Margin="0,30,0,10"/>

        <VerticalStackLayout Spacing="10" Padding="20">
            <Label Text="✓ Tworzenie nowych zleceń" FontSize="14"/>
            <Label Text="✓ Przypisywanie pracowników" FontSize="14"/>
            <Label Text="✓ Zarządzanie flotą pojazdów" FontSize="14"/>
            <Label Text="✓ Raporty i statystyki" FontSize="14"/>
        </VerticalStackLayout>

        <Button Text="🚪 Wyloguj"
                Clicked="OnLogoutClicked"
                BackgroundColor="{StaticResource Danger}"
                TextColor="White"
                FontSize="18"
                Margin="0,40,0,0"
                CornerRadius="10"
                Padding="20,15"/>
    </VerticalStackLayout>
</ContentPage>