<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MauiAppMobile.Views.Authentication"
       xmlns:employee="clr-namespace:MauiAppMobile.Views.Employee"
       xmlns:admin="clr-namespace:MauiAppMobile.Views.Administrator"
       x:Class="MauiAppMobile.AppShell"
       FlyoutBehavior="Disabled">

    <!-- Login -->
    <ShellContent
        Title="Login"
        Route="Login"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Employee Dashboard -->
    <ShellContent
        Title="Dashboard"
        Route="EmployeeDashboard"
        ContentTemplate="{DataTemplate employee:EmployeeDashboardPage}" />

    <!-- Admin Dashboard -->
    <ShellContent
    Title="Admin Dashboard"
    Route="AdminDashboard"
    ContentTemplate="{DataTemplate admin:AdminDashboardPage}" />

</Shell>